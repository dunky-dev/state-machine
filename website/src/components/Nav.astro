---
import { nav } from '../nav'

const base = import.meta.env.BASE_URL
const here = Astro.url.pathname.replace(base, '/').replace(/\/$/, '') || '/'
const withBase = (href: string) => `${base}${href.replace(/^\//, '')}`
---

<!-- Backdrop (mobile only) -->
<div
  id="nav-backdrop"
  class="fixed inset-0 z-30 bg-black/60 opacity-0 backdrop-blur-sm transition-opacity duration-200 md:hidden"
  style="pointer-events:none"
  aria-hidden="true"
></div>

<aside
  id="sidebar"
  class="fixed inset-y-0 left-0 z-40 w-72 -translate-x-full overflow-y-auto bg-[#0a0a0d] px-6 py-8 shadow-2xl transition-transform duration-200 md:static md:block md:w-56 md:translate-x-0 md:overflow-visible md:bg-transparent md:px-0 md:py-0 md:shadow-none md:border-r md:border-border md:pr-6"
>
  <!-- Close button (mobile only) -->
  <button
    id="nav-close"
    aria-label="Close navigation"
    class="mb-6 flex items-center gap-2 text-sm text-white/50 md:hidden"
  >
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 4L4 12M4 4l8 8"/>
    </svg>
    Close
  </button>

  <nav>
    {nav.map((group) => (
      <section class="mb-6">
        <h4 class="mb-2 text-xs font-medium uppercase tracking-wider text-muted">
          {group.title}
        </h4>
        <ul class="space-y-1">
          {group.items.map((item) => (
            <li>
              <a
                href={withBase(item.href)}
                aria-current={here === item.href ? 'page' : undefined}
                class:list={[
                  'block text-sm transition-colors hover:text-fg',
                  here === item.href ? 'font-semibold text-fg' : 'text-muted',
                ]}
              >
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </nav>
</aside>

<script>
  const toggle   = document.getElementById('nav-toggle')!
  const close    = document.getElementById('nav-close')!
  const sidebar  = document.getElementById('sidebar')!
  const backdrop = document.getElementById('nav-backdrop')!

  function open() {
    sidebar.classList.remove('-translate-x-full')
    backdrop.style.pointerEvents = 'auto'
    backdrop.classList.remove('opacity-0')
    backdrop.classList.add('opacity-100')
    toggle.setAttribute('aria-expanded', 'true')
    document.body.style.overflow = 'hidden'
  }

  function shut() {
    sidebar.classList.add('-translate-x-full')
    backdrop.style.pointerEvents = 'none'
    backdrop.classList.remove('opacity-100')
    backdrop.classList.add('opacity-0')
    toggle.setAttribute('aria-expanded', 'false')
    document.body.style.overflow = ''
  }

  toggle.addEventListener('click', open)
  close.addEventListener('click', shut)
  backdrop.addEventListener('click', shut)

  sidebar.querySelectorAll('a').forEach(a => a.addEventListener('click', shut))
</script>
