---
interface Props {
  type?: 'note' | 'warning' | 'tip'
}
const { type = 'note' } = Astro.props
const styles = {
  note:    'border-accent/30 bg-accent/5 text-fg',
  warning: 'border-down/30 bg-down/5 text-fg',
  tip:     'border-up/30 bg-up/5 text-fg',
}
---

<aside class={`not-prose my-6 rounded-lg border px-5 py-4 text-sm leading-relaxed ${styles[type]}`}>
  <slot />
</aside>
