---
// The top bar shown on every page: logo (left) + Docs / GitHub (right),
// contents centered in a max-width container that lines up with page content.
//
// On the homepage the bar is hidden and only slides in after the visitor has
// scrolled past the hero (~500px). Pass `revealOnScroll` to enable that; every
// other page keeps the bar pinned and always visible.
// `trailingSlash: 'never'` strips BASE_URL's trailing slash, so normalize to
// exactly one slash before the `${base}…` concatenations below resolve.
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/')
const repo = 'https://github.com/dunky-dev/state-machine'

interface Props {
  revealOnScroll?: boolean
}
const { revealOnScroll = false } = Astro.props
---

<header
  id="site-header"
  data-reveal={revealOnScroll ? 'true' : undefined}
  class="sticky top-0 z-50 bg-black "
>
  <div class="
  mx-auto max-w-5xl sm:px-6 xl:max-w-6xl 2xl:max-w-[88rem] min-[1800px]:max-w-[104rem]
  flex items-center justify-between px-4 py-5 sm:px-6">
    <a href={base} aria-label="Dunky home" class="shrink-0">
      <img src={`${base}logo/logo.svg`} alt="Dunky" class="h-8 w-auto invert" />
    </a>
    <nav class="flex items-center gap-6 text-[15px] sm:gap-8">
      <a href={`${base}get-started`} class="text-white/70 transition-colors hover:text-white">Docs</a>
      <a
        href={repo}
        target="_blank"
        rel="noreferrer"
        class="text-white/70 transition-colors hover:text-white">GitHub</a
      >
      <button
        id="nav-toggle"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="sidebar"
        class="flex h-8 w-8 flex-col items-center justify-center gap-[5px] rounded text-white md:hidden"
      >
        <span class="block h-px w-5 bg-current transition-all duration-200"></span>
        <span class="block h-px w-5 bg-current transition-all duration-200"></span>
        <span class="block h-px w-5 bg-current transition-all duration-200"></span>
      </button>
    </nav>
  </div>
</header>

{
  revealOnScroll && (
    <script>
      // Hide the bar over the hero; reveal it (slide down) once the visitor has
      // scrolled past 500px, hide it again when they return to the top.
      const header = document.getElementById('site-header')!
      const THRESHOLD = 72
      let shown = false
      const sync = () => {
        const past = window.scrollY > THRESHOLD
        if (past === shown) return
        shown = past
        header.dataset.shown = String(past)
      }
      sync()
      addEventListener('scroll', sync, { passive: true })
    </script>

    <style is:global>
      /* Reveal-on-scroll header: parked above the viewport until scrolled. */
      #site-header[data-reveal] {
        transition:
          transform 0.28s ease,
          opacity 0.28s ease;
        transform: translateY(-100%);
        opacity: 0;
        pointer-events: none;
      }
      #site-header[data-reveal][data-shown='true'] {
        transform: translateY(0);
        opacity: 1;
        pointer-events: auto;
      }
    </style>
  )
}
