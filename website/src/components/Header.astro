---
// The top bar shown on every page: logo (left) + Docs / GitHub (right),
// contents centered in a max-width container that lines up with page content.
const base = import.meta.env.BASE_URL
const repo = 'https://github.com/chimba-ui/state-machine'
---

<header class="sticky top-0 z-50 bg-black">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-5 sm:px-6">
    <a href={base} aria-label="Chimba UI home" class="shrink-0">
      <img src={`${base}logo.svg`} alt="Chimba" class="h-8 w-auto invert" />
    </a>
    <nav class="flex items-center gap-6 text-[15px] sm:gap-8">
      <a href={`${base}get-started`} class="text-white/70 transition-colors hover:text-white">Docs</a>
      <a
        href={repo}
        target="_blank"
        rel="noreferrer"
        class="text-white/70 transition-colors hover:text-white">GitHub</a
      >
    </nav>
  </div>
</header>
