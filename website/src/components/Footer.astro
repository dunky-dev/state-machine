---
const repo = "https://github.com/chimba-ui/state-machine";
const twitter = "https://x.com/ivanbanov";
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- left: made with love -->
    <p class="footer-credit">
      Made with <span class="footer-heart" aria-label="love">♥</span> by
      <a href={twitter} target="_blank" rel="noreferrer" class="footer-name"
        >Ivan Banov</a
      >
    </p>

    <!-- right: links + fun easter-egg -->
    <div class="footer-links">
      <a
        href={twitter}
        target="_blank"
        rel="noreferrer"
        class="footer-link"
        aria-label="X / Twitter"
      >
        <!-- X logo -->
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L2.25 2.25h6.988l4.26 5.634zm-1.161 17.52h1.833L7.084 4.126H5.117z"
          ></path>
        </svg>
        <span>@ivanbanov</span>
      </a>

      <span class="footer-sep" aria-hidden="true">·</span>

      <a
        href={repo}
        target="_blank"
        rel="noreferrer"
        class="footer-link"
        aria-label="GitHub"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
        <span>GitHub</span>
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: radial-gradient(
      120% 120% at 15% 0%,
      #15171c 0%,
      #0b0c0f 55%,
      #050507 100%
    );
    color: #fff;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .footer-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 1.5rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .footer-credit {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .footer-heart {
    color: #ff5d52;
    font-size: 12px;
  }
  .footer-name {
    color: rgba(255, 255, 255, 0.75);
    font-weight: 500;
    transition: color 0.15s;
    text-decoration: none;
  }
  .footer-name:hover {
    color: #fff;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-link:hover {
    color: rgba(255, 255, 255, 0.9);
  }
  .footer-sep {
    color: rgba(255, 255, 255, 0.15);
    font-size: 12px;
  }
</style>
