    <script>
      import { createGame, MAZE, ROWS, COLS, key, type Dir } from "../demos/pacman";
      import { createTradingDemo, type PairState } from "../demos/trading";
      import {
        createWhiteboardDemo,
        CURSOR_COLORS,
        CURSOR_NAMES,
      } from "../demos/whiteboard";

      // THREE machines (pacman · ghost · board) composed into one game. Three
      // renderers read the SAME composed state and paint it three ways.
      const game = createGame();
      const { pacman, ghost, board } = game;

      // --- TUI renderer FACTORY: same composed state, painted into ANY <pre>. ---
      // This is the whole pitch (option B): one machine, many render targets. Each
      // call builds a fixed monospace grid and returns a paint() that reads the
      // SHARED game state. Cells are rigid CSS boxes so glyphs never widen a row.
      const PAC = "🟡";
      const makeTuiRenderer = (pre: HTMLElement) => {
        const cells: HTMLElement[] = [];
        for (let y = 0; y < ROWS; y++) {
          const row = document.createElement("div");
          row.className = "tui-row";
          for (let x = 0; x < COLS; x++) {
            const c = document.createElement("span");
            c.className = "tui-cell";
            row.appendChild(c);
            cells.push(c);
          }
          pre.appendChild(row);
        }
        return () => {
          const p = pacman.context;
          const g = ghost.context;
          const b = board.context;
          for (let y = 0; y < ROWS; y++) {
            for (let x = 0; x < COLS; x++) {
              const c = cells[y * COLS + x];
              let ch = " ";
              if (x === p.x && y === p.y)
                ch = pacman.state === "dead" ? "💀" : PAC;
              else if (x === g.x && y === g.y && ghost.state !== "stopped")
                ch = "👻";
              else if (b.cherry && x === b.cherry.x && y === b.cherry.y)
                ch = "🍒";
              else if (MAZE[y][x] === 1) ch = "🟦";
              else if (b.dots.has(key(x, y))) ch = "·";
              if (c.textContent !== ch) c.textContent = ch;
            }
          }
        };
      };

      // ONE machine, many render targets (the whole pitch). Mount a renderer on
      // the hero board and on each device frame; they ALL read the shared state,
      // so they stay byte-for-byte in sync. Static — no scroll effects.
      const painters: Array<() => void> = [];
      const heroPre = document.getElementById("render-tui");
      if (heroPre) painters.push(makeTuiRenderer(heroPre));
      document
        .querySelectorAll<HTMLElement>(".frame-tui")
        .forEach((pre) => painters.push(makeTuiRenderer(pre)));
      const paintTui = () => {
        for (const paint of painters) paint();
      };

      // --- live state TABLE: state + context per machine -----------------------
      // Values are padded to fixed widths so the { … } never changes size and the
      // table stays rock-still as numbers tick (no layout jitter).
      const stPacman = document.getElementById("st-pacman")!;
      const stGhost = document.getElementById("st-ghost")!;
      const stBoard = document.getElementById("st-board")!;
      const cxPacman = document.getElementById("cx-pacman")!;
      const cxGhost = document.getElementById("cx-ghost")!;
      const cxBoard = document.getElementById("cx-board")!;
      // mobile duplicates
      const mStPacman = document.getElementById("m-st-pacman")!;
      const mStGhost = document.getElementById("m-st-ghost")!;
      const mStBoard = document.getElementById("m-st-board")!;
      const mCxPacman = document.getElementById("m-cx-pacman")!;
      const mCxGhost = document.getElementById("m-cx-ghost")!;
      const mCxBoard = document.getElementById("m-cx-board")!;
      const n2 = (v: number) => String(v).padStart(2, " ");
      const dir5 = (d: Dir) => d.padEnd(5, " ");
      const paintDebug = () => {
        const p = pacman.context;
        const g = ghost.context;
        const b = board.context;
        const pacSt = pacman.state;
        const ghSt = ghost.state;
        const bdSt = board.state;
        const pacCx = `{ x:${n2(p.x)} y:${n2(p.y)} dir:${dir5(p.dir)} }`;
        const ghCx = `{ x:${n2(g.x)} y:${n2(g.y)} dir:${dir5(g.dir)} }`;
        const bdCx = `{ score:${String(b.score).padStart(4, " ")} }`;
        stPacman.textContent = pacSt;
        mStPacman.textContent = pacSt;
        stGhost.textContent = ghSt;
        mStGhost.textContent = ghSt;
        stBoard.textContent = bdSt;
        mStBoard.textContent = bdSt;
        cxPacman.textContent = pacCx;
        mCxPacman.textContent = pacCx;
        cxGhost.textContent = ghCx;
        mCxGhost.textContent = ghCx;
        cxBoard.textContent = bdCx;
        mCxBoard.textContent = bdCx;
      };

      // --- one render pass paints all renderers + the live state table --------
      const render = () => {
        paintTui();
        paintDebug();
      };
      // any member changing repaints everything (coarse, like the docs' sync)
      game.group.sync(render);
      game.group.start();
      render();

      // --- "connection" wires: one per machine row → into the board -----------
      // Drawn as SVG paths from the right edge of each table row, out to a shared
      // bus, down, and into the top of the running board. Each carries a flowing
      // dot in the machine's color. Recomputed on load/resize so it stays exact.
      const SVG_NS = "http://www.w3.org/2000/svg";
      const card = document.getElementById("pac-card")!;
      const wires = document.getElementById("pac-wires")!;
      const tuiEl = document.getElementById("render-tui")!;
      // line = the light cable tint; dot = the bright signal traveling it
      const WIRE: { row: string; line: string; dot: string }[] = [
        { row: "row-pacman", line: "#fff1a8", dot: "#ffe66d" }, // light yellow
        { row: "row-ghost", line: "#a9d3ff", dot: "#62b3ff" }, // light blue
        { row: "row-board", line: "#ffb0ab", dot: "#ff5d52" }, // light red/pink
      ];
      const drawWires = () => {
        const cb = card.getBoundingClientRect();
        if (!cb.width) return;
        wires.setAttribute("viewBox", `0 0 ${cb.width} ${cb.height}`);
        wires.innerHTML = "";
        // board geometry, in card-local coords
        const b = tuiEl.getBoundingClientRect();
        const boardRight = b.right - cb.left; // board's right edge (plug line)
        const boardTop = b.top - cb.top;
        const boardH = b.height;
        const LANE_STEP = 14; // how much further out each successive wire bows
        const PLUG_STEP = boardH / 4; // vertical spacing of plugs on board edge
        // Each wire leaves its row at the card's right edge, bows OUTSIDE the card
        // (to x > card width), arcs down, then comes back IN to plug into the
        // board's right edge. Outer wires bow further so the three nest cleanly.
        WIRE.forEach((w, i) => {
          const r = document.getElementById(w.row)!.getBoundingClientRect();
          const ry = r.top - cb.top + r.height / 2; // row mid-height
          const sx = cb.width; // exit exactly at the card's right edge
          const outX = cb.width + 22 + i * LANE_STEP; // vertical lane, outside card
          const plugY = boardTop + PLUG_STEP * (i + 1); // where it re-enters board
          // SQUARED (orthogonal) out-and-back: exit right → out to lane → straight
          // down → back in to the board's right edge. Right angles only.
          const d =
            `M ${sx} ${ry} ` + `H ${outX} ` + `V ${plugY} ` + `H ${boardRight}`;
          // a single solid light-tint line for the cable
          const line = document.createElementNS(SVG_NS, "path");
          line.setAttribute("d", d);
          line.setAttribute("fill", "none");
          line.setAttribute("stroke", w.line);
          line.setAttribute("stroke-width", "1.5");
          line.setAttribute("stroke-linejoin", "miter");
          line.setAttribute("stroke-linecap", "butt");
          wires.appendChild(line);
          // the "signal" dot: a solid bright dot with a glow, traveling the line
          const dot = document.createElementNS(SVG_NS, "circle");
          dot.setAttribute("r", "3");
          dot.setAttribute("fill", w.dot);
          const motion = document.createElementNS(SVG_NS, "animateMotion");
          motion.setAttribute("path", d);
          motion.setAttribute("dur", "2.2s");
          motion.setAttribute("begin", `${i * 0.5}s`);
          motion.setAttribute("repeatCount", "indefinite");
          motion.setAttribute("rotate", "auto");
          dot.appendChild(motion);
          wires.appendChild(dot);
        });
      };
      // always draw the cables; the CSS pauses the signal dot for reduced motion
      drawWires();
      addEventListener("resize", drawWires, { passive: true });
      setTimeout(drawWires, 250); // redraw once fonts/layout settle

      // --- drive it: the autopilot runs the game on a fixed tick --------------
      // tick() fans the shared step to all three machines; the autopilot's choice
      // (nextDir) decides Pac-Man's direction — no player input.
      let paused = false;
      setInterval(() => {
        if (!paused) game.tick();
      }, 200);

      // play / pause — two icon buttons under the demo. Pausing also freezes the
      // SVG signal dots traveling the wires, so game + wires stop together. The
      // active control is highlighted via [data-paused] on the wrapper.
      const controls = document.getElementById("pac-controls")!;
      const wireSvg = document.getElementById(
        "pac-wires",
      ) as unknown as SVGSVGElement;
      const setPaused = (next: boolean) => {
        paused = next;
        controls.dataset.paused = String(paused);
        if (paused) wireSvg.pauseAnimations();
        else wireSvg.unpauseAnimations();
      };
      document
        .getElementById("pac-play")!
        .addEventListener("click", () => setPaused(false));
      document
        .getElementById("pac-pause")!
        .addEventListener("click", () => setPaused(true));

      // The game panel rides down the page via native `position: sticky` (see
      // the right column markup) — no JS scroll handler, so no render flicker.

      // --- connector + cassette wiring --------------------------------------
      // The connector is a permanent hub wired to the three (always-live) frames
      // by black, rounded-corner orthogonal cables (plug at each end). The game
      // cassette slides DOWN the right column on scroll and PARKS a bit above the
      // connector; a feed cable joins the two.
      const dock = document.getElementById("dock")!;
      const cables = document.getElementById("cables")!;
      const heroLive = document.getElementById("hero-live")!;
      const FRAME_IDS = ["frame-laptop", "frame-phone", "frame-terminal"];
      // cables only make sense on lg+, where the connector and frames sit apart;
      // on mobile everything stacks, so we skip them.
      const wideDock = matchMedia("(min-width: 1024px)");

      // a small plug rectangle centred on (x, y)
      const plug = (x: number, y: number) => {
        const p = document.createElementNS(SVG_NS, "rect");
        p.setAttribute("x", String(x - 4));
        p.setAttribute("y", String(y - 3));
        p.setAttribute("width", "8");
        p.setAttribute("height", "6");
        p.setAttribute("rx", "1.5");
        p.setAttribute("class", "cable-plug");
        return p;
      };
      // draw the three cables: cassette bottom → each frame top, orthogonal with
      // rounded corners (drop straight down, run across, drop into the frame).
      const R = 10; // corner radius
      const drawCables = () => {
        cables.innerHTML = "";
        if (!wideDock.matches) return;
        const base = broadcast.getBoundingClientRect();
        if (!base.width) return;
        cables.setAttribute("viewBox", `0 0 ${base.width} ${base.height}`);
        const d = dock.getBoundingClientRect();
        const sx = d.left + d.width / 2 - base.left; // console bottom-center
        const sy = d.bottom - base.top;
        const busY = sy + 26; // shared horizontal bus just below the console
        for (const id of FRAME_IDS) {
          const fig = document.getElementById(id);
          if (!fig) continue;
          // anchor to the device CHASSIS (not the figure, which also holds the
          // caption) so the plug always lands on the device's top edge.
          const el =
            fig.querySelector<HTMLElement>(
              ".laptop-screen, .iphone, .terminal",
            ) ?? fig;
          const r = el.getBoundingClientRect();
          const ex = r.left + r.width / 2 - base.left; // device top-center
          const ey = r.top - base.top;
          let path: string;
          if (Math.abs(ex - sx) < R * 2) {
            // (near-)straight below the cassette — drop straight down, no jog
            path = `M ${sx} ${sy} V ${ey}`;
          } else {
            // drop from the cassette, rounded turn onto the bus, run across,
            // rounded turn, drop into the frame. Right angles + rounded corners.
            const dir = Math.sign(ex - sx);
            path =
              `M ${sx} ${sy} ` +
              `V ${busY - R} ` +
              `Q ${sx} ${busY} ${sx + dir * R} ${busY} ` +
              `H ${ex - dir * R} ` +
              `Q ${ex} ${busY} ${ex} ${busY + R} ` +
              `V ${ey}`;
          }
          const line = document.createElementNS(SVG_NS, "path");
          line.setAttribute("d", path);
          line.setAttribute("class", "cable");
          cables.appendChild(line);
          cables.appendChild(plug(sx, sy)); // plug at the console
          cables.appendChild(plug(ex, ey)); // plug at the frame
        }
      };

      // scroll-driven park: the cassette slides down and stops a bit ABOVE the
      // connector (a gap), held there with a translateY clamp. No activation —
      // the frames are always live. Negative gap parks it LOWER (onto the
      // console) — move the stop point down a touch.
      const PARK_GAP = -40; // px relative to the console top (− = lower/into it)
      const parkCassette = () => {
        if (!wideDock.matches) {
          heroLive.style.transform = "";
          return;
        }
        const stopY = dock.getBoundingClientRect().top - PARK_GAP;
        // measure the cassette's UN-clamped bottom (ignore any park transform)
        heroLive.style.transform = "";
        const cassetteBottom = heroLive.getBoundingClientRect().bottom;
        const overshoot = cassetteBottom - stopY;
        if (overshoot > 0) {
          heroLive.style.transform = `translateY(${-overshoot}px)`;
        }
      };

      // the cassette can overflow its grid cell, so its right edge won't match
      // the container edge the console aligns to. Nudge the console so its right
      // edge sits exactly under the cassette's — perfectly aligned + same width.
      const alignConsole = () => {
        dock.style.transform = "";
        if (!wideDock.matches) return;
        const casRight = heroLive.getBoundingClientRect().right;
        const conRight = dock.getBoundingClientRect().right;
        const dx = casRight - conRight;
        if (dx) dock.style.transform = `translateX(${dx}px)`;
      };

      // FEED cable: from the cassette's bottom down to the console. The cassette
      // is sticky, so this MUST track scroll — but it's a single cheap path in
      // its own SVG (#feed-cable), so it doesn't rebuild the frame cables.
      const feed = document.getElementById(
        "feed-cable",
      )! as unknown as SVGSVGElement;
      const drawFeed = () => {
        feed.innerHTML = "";
        if (!wideDock.matches) return;
        const hb = heroLive.getBoundingClientRect();
        const db = dock.getBoundingClientRect();
        if (!hb.width || !db.width) return;
        feed.setAttribute("viewBox", `0 0 ${hb.width} ${hb.height}`);
        const cx = hb.width / 2; // cassette bottom-center (local X)
        const cy = hb.height; // cassette bottom (local Y)
        const tx = db.left + db.width / 2 - hb.left; // console top-center
        const ty = db.top - hb.top;
        if (ty <= cy) return; // console above/overlapping the cassette → no cable
        let path: string;
        if (Math.abs(tx - cx) < R * 2) {
          path = `M ${cx} ${cy} V ${ty}`;
        } else {
          const midY = (cy + ty) / 2;
          const dir = Math.sign(tx - cx);
          path =
            `M ${cx} ${cy} ` +
            `V ${midY - R} ` +
            `Q ${cx} ${midY} ${cx + dir * R} ${midY} ` +
            `H ${tx - dir * R} ` +
            `Q ${tx} ${midY} ${tx} ${midY + R} ` +
            `V ${ty}`;
        }
        const line = document.createElementNS(SVG_NS, "path");
        line.setAttribute("d", path);
        line.setAttribute("class", "cable");
        feed.appendChild(line);
        feed.appendChild(plug(cx, cy)); // plug at the cassette
        feed.appendChild(plug(tx, ty)); // plug at the console
      };

      // the console→frames cables are in normal flow — only redraw on RESIZE.
      // The feed cable + dock toggle track scroll (both cheap).
      addEventListener(
        "scroll",
        () => {
          parkCassette();
          drawFeed();
        },
        { passive: true },
      );
      addEventListener(
        "resize",
        () => {
          alignConsole();
          drawCables();
          drawFeed();
          parkCassette();
        },
        { passive: true },
      );
      alignConsole();
      drawCables();
      parkCassette();
      drawFeed();
      // redraw once after fonts/layout settle (one-off, not on every scroll)
      setTimeout(() => {
        alignConsole();
        drawCables();
        parkCassette();
        drawFeed();
      }, 250);

      // =====================================================================
      // TRADING PANEL — powered by demos/trading.ts real machines
      // =====================================================================
      {
        const demo = createTradingDemo();
        demo.group.start();

        let activePair = 0;

        const priceEl = document.getElementById("trade-price")!;
        const deltaEl = document.getElementById("trade-delta")!;
        const posEl = document.getElementById("trade-position")!;
        const badge = document.getElementById("trade-state-badge")!;
        const chartLine = document.getElementById(
          "trade-line",
        )! as SVGPolylineElement;
        const btnBuy = document.getElementById("btn-buy") as HTMLButtonElement;
        const btnSell = document.getElementById(
          "btn-sell",
        ) as HTMLButtonElement;
        const btnCancl = document.getElementById(
          "btn-cancel",
        ) as HTMLButtonElement;

        const BADGE_COLORS: Record<PairState, string> = {
          idle: "#6b7678",
          buying: "#ffe66d",
          holding: "#a2e57b",
          selling: "#ff5d52",
        };

        const decPlaces = (price: number) =>
          price < 1 ? 4 : price < 200 ? 2 : 0;

        const renderTrade = () => {
          const m = demo.pairs[activePair]!;
          const { price, prevPrice, history, entryPrice, pnl } = m.context;
          const { isUp } = m.computed;
          const state = m.state;
          const dec = decPlaces(price);
          const delta = price - prevPrice;

          priceEl.textContent = price.toFixed(dec);
          deltaEl.textContent = (delta >= 0 ? "+" : "") + delta.toFixed(dec);
          deltaEl.className = "trade-delta " + (isUp ? "up" : "down");
          badge.textContent = state;
          badge.style.background = BADGE_COLORS[state];
          badge.style.color = state === "buying" ? "#16161a" : "#fff";

          // sparkline from machine's history
          const pts = history.slice(-40);
          const mn = Math.min(...pts),
            mx = Math.max(...pts);
          const range = mx - mn || 1;
          chartLine.setAttribute(
            "points",
            pts
              .map(
                (v, i) =>
                  `${(i / Math.max(pts.length - 1, 1)) * 200},${52 - ((v - mn) / range) * 48}`,
              )
              .join(" "),
          );
          chartLine.setAttribute("stroke", isUp ? "#a2e57b" : "#ff5d52");

          if (state === "holding") {
            posEl.textContent = `${entryPrice.toFixed(dec)} to ${price.toFixed(dec)} (${pnl >= 0 ? "+" : ""}${pnl.toFixed(dec)})`;
            posEl.className = "trade-order-val " + (pnl >= 0 ? "up" : "down");
          } else {
            posEl.textContent = state === "idle" ? "—" : state + "…";
            posEl.className = "trade-order-val";
          }

          btnBuy.disabled = state !== "idle";
          btnSell.disabled = state !== "holding";
          btnCancl.disabled = state !== "buying";
        };

        // symbol strip — subscribe to each pair machine for fine-grained updates
        const symPriceEls = [0, 1, 2].map(
          (i) => document.getElementById(`sym-price-${i}`)!,
        );
        const symArrowEls = [0, 1, 2].map(
          (i) => document.getElementById(`sym-arrow-${i}`)!,
        );

        demo.pairs.forEach((m, i) => {
          m.subscribe(() => {
            const { price, prevPrice } = m.context;
            const up = price >= prevPrice;
            const dec = decPlaces(price);
            symPriceEls[i]!.textContent = price.toFixed(dec);
            symArrowEls[i]!.textContent = up ? "▲" : "▼";
            symArrowEls[i]!.className =
              "trade-sym-arrow " + (up ? "up" : "down");
            const row = symPriceEls[i]!.closest<HTMLElement>(".trade-sym")!;
            row.classList.remove("flash-up", "flash-down");
            void row.offsetWidth;
            row.classList.add(up ? "flash-up" : "flash-down");
            if (i === activePair) renderTrade();
          });
        });

        // BUY / SELL / CANCEL forward directly to the active pair machine
        btnBuy.addEventListener("click", () => {
          demo.pairs[activePair]!.send({ type: "BUY" });
        });
        btnSell.addEventListener("click", () => {
          demo.pairs[activePair]!.send({ type: "SELL" });
        });
        btnCancl.addEventListener("click", () => {
          demo.pairs[activePair]!.send({ type: "CANCEL" });
        });

        // pair selection
        document
          .querySelectorAll<HTMLButtonElement>(".trade-sym")
          .forEach((btn) => {
            btn.addEventListener("click", () => {
              activePair = Number(btn.dataset.pair);
              document
                .querySelectorAll(".trade-sym")
                .forEach((t) => t.classList.remove("trade-sym-active"));
              btn.classList.add("trade-sym-active");
              renderTrade();
            });
          });

        // accordion
        const tradeToggle = document.getElementById("trade-code-toggle")!;
        const tradePanel = document.getElementById("trade-code-panel")!;
        tradeToggle.addEventListener("click", () => {
          const open = tradeToggle.getAttribute("aria-expanded") === "true";
          tradeToggle.setAttribute("aria-expanded", String(!open));
          tradePanel.hidden = open;
          tradeToggle.querySelector(".trade-accordion-chevron")!.textContent =
            open ? "▸" : "▾";
        });

        renderTrade();
      }

      // =====================================================================
      // WHITEBOARD — powered by demos/whiteboard.ts real machines
      // =====================================================================
      {
        const STICKY_DATA = [
          { text: "Redesign header\nfor mobile", color: "#ffe66d" },
          { text: "Fix tooltip on\ncanvas nodes", color: "#a2e57b" },
        ];

        const canvas = document.getElementById("wb-canvas")!;
        const wbBadge = document.getElementById("wb-state-badge")!;

        const demo = createWhiteboardDemo();
        demo.group.start();

        // build cursor DOM elements, keyed to their machine
        const cursorEls: HTMLElement[] = demo.cursors.map((m, i) => {
          const color = CURSOR_COLORS[i]!;
          const el = document.createElement("div");
          el.className = "wb-cursor";
          el.innerHTML = `<svg width="14" height="18" viewBox="0 0 14 18" fill="none"><path d="M0 0l14 10-6.5 1.5L5 18z" fill="${color}"/></svg>`;
          const label = document.createElement("span");
          label.className = "wb-cursor-label";
          label.textContent = CURSOR_NAMES[i]!;
          label.style.background = color;
          el.appendChild(label);
          canvas.appendChild(el);
          // subscribe: re-render this cursor whenever its machine changes
          m.subscribe(() => {
            el.style.left = m.computed.ex + "%";
            el.style.top = m.computed.ey + "%";
          });
          return el;
        });
        void cursorEls; // used via subscribe side-effects

        // build sticky DOM elements, wire pointer events to machine events
        demo.stickies.forEach((m, i) => {
          const d = STICKY_DATA[i]!;
          const el = document.createElement("div");
          el.className = "wb-sticky";
          el.style.background = d.color;
          const txt = document.createElement("p");
          txt.className = "wb-sticky-text";
          txt.textContent = d.text;
          const stEl = document.createElement("span");
          stEl.className = "wb-sticky-state";
          el.appendChild(txt);
          el.appendChild(stEl);
          canvas.appendChild(el);

          // subscribe: sync DOM from machine context
          m.subscribe(() => {
            el.style.left = m.computed.normalizedX + "%";
            el.style.top = m.computed.normalizedY + "%";
            stEl.textContent = m.state;
            el.classList.toggle("wb-sticky-dragging", m.state === "dragging");
          });

          // pointer events → machine events
          el.addEventListener("pointerdown", (e) => {
            const r = canvas.getBoundingClientRect();
            const offsetX = e.clientX - r.left - (m.context.x / 100) * r.width;
            const offsetY = e.clientY - r.top - (m.context.y / 100) * r.height;
            m.send({ type: "DRAG_START", offsetX, offsetY });
            el.setPointerCapture(e.pointerId);
            e.preventDefault();
          });
          el.addEventListener("pointermove", (e) => {
            if (m.state !== "dragging") return;
            m.send({
              type: "DRAG_MOVE",
              clientX: e.clientX,
              clientY: e.clientY,
              canvasRect: canvas.getBoundingClientRect(),
            });
          });
          el.addEventListener("pointerup", () => {
            m.send({ type: "DROP" });
          });

          // initial position
          el.style.left = m.context.x + "%";
          el.style.top = m.context.y + "%";
        });

        // accordion
        const wbToggle = document.getElementById("wb-code-toggle")!;
        const wbPanel = document.getElementById("wb-code-panel")!;
        wbToggle.addEventListener("click", () => {
          const open = wbToggle.getAttribute("aria-expanded") === "true";
          wbToggle.setAttribute("aria-expanded", String(!open));
          wbPanel.hidden = open;
          wbToggle.querySelector(".trade-accordion-chevron")!.textContent = open
            ? "▸"
            : "▾";
        });

        wbBadge.textContent = "live";
      }

      // copy the install command
      const copyBtn = document.getElementById("install-copy");
      const cmd = document.getElementById("install-cmd");
      copyBtn?.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(cmd?.textContent ?? "");
          const prev = copyBtn.textContent;
          copyBtn.textContent = "✓";
          setTimeout(() => (copyBtn.textContent = prev), 1200);
        } catch {
          /* clipboard blocked — no-op */
        }
      });
    </script>

    <!-- is:global because the code spans are injected via set:html and so don't
