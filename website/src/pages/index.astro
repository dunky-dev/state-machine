      .contrib-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
        margin-bottom: 2rem;
      }
      .contrib-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        font-weight: 600;
        padding: 0.65rem 1.25rem;
        border-radius: 0.75rem;
        text-decoration: none;
        transition:
          opacity 0.15s,
          transform 0.15s;
        white-space: nowrap;
      }
      .contrib-btn:hover {
        opacity: 0.85;
        transform: translateY(-1px);
      }
      .contrib-btn-primary {
        background: var(--color-fg);
        color: var(--color-bg);
      }
      .contrib-btn-secondary {
        background: transparent;
        color: var(--color-fg);
        border: 1px solid var(--color-border);
      }
      .contrib-note {
        font-size: 0.875rem;
        color: var(--color-muted);
      }

      /* play / pause icon controls on the dark cassette deck: dim grey by
         default, bright + chip-highlighted for the ACTIVE one. data-paused on
         the wrapper flips which is "on": playing → play active; paused → pause. */
      #pac-controls .pac-ctrl {
        color: #6b7079;
      }
      #pac-controls .pac-ctrl:hover {
        color: #c9ccd6;
      }
      #pac-controls[data-paused="false"] #pac-play,
      #pac-controls[data-paused="true"] #pac-pause {
        color: #fff;
        background: rgba(255, 255, 255, 0.1);
      }

      /* Dark surface for code panels + demo cards, so source/glyphs stay legible
         against the light page. Use class "dark-card" on the card element. */
      .dark-card {
        background: var(--color-code);
        border: 1px solid var(--color-code-border);
        color: var(--color-code-fg);
        border-radius: 1rem;
        box-shadow:
          0 1px 2px rgba(0, 0, 0, 0.08),
          0 12px 30px rgba(0, 0, 0, 0.12);
      }
      .dark-card .panel-head {
        border-bottom: 1px solid var(--color-code-border);
        color: var(--color-code-muted);
      }

      /* IDE card: one dark surface holding several files, divided by hairlines */
      .ide-card > figure + figure {
        border-top: 1px solid var(--color-code-border);
      }

      /* --- code panel: syntax tokens, Monokai Pro (Filter Machine) palette --- */
      .cmt {
        color: #6b7678; /* comment */
      }
      .kw {
        color: #ff6d7e; /* red — keyword */
      }
      .str {
        color: #ffed72; /* yellow — string */
      }
      .fn {
        color: #a2e57b; /* green — function */
      }
      .num {
        color: #ffb86b; /* orange — number */
      }
      /* the three state lines render as plain code — no live highlight */
      .st {
        color: var(--color-code-fg);
      }

      /* live state table — fixed layout so columns never reflow as values tick */
      .pac-table {
        table-layout: fixed;
        border-collapse: collapse;
        /* tabular figures: every digit is the same width, so numbers never shift */
        font-variant-numeric: tabular-nums;
      }
      /* context cell: preserve the padding spaces + lock the width so the closing
         "}" never moves (no "dancing" brackets as values tick) */
      .cx-cell {
        white-space: pre;
        font-variant-numeric: tabular-nums;
      }
      /* give the context column the room it needs; machine/state stay compact */
      .pac-table th:nth-child(1),
      .pac-table td:nth-child(1) {
        width: 30%;
      }
      .pac-table th:nth-child(2),
      .pac-table td:nth-child(2) {
        width: 22%;
      }
      .pac-table th:nth-child(3),
      .pac-table td:nth-child(3) {
        width: 48%;
      }
      .pac-table th {
        color: var(--color-code-muted);
      }
      .pac-table thead th {
        border-bottom: 1px solid var(--color-code-border);
      }
      .pac-table td {
        vertical-align: top;
        white-space: nowrap;
      }
      /* "connection" wires (SVG): a single solid light-tint cable per machine,
         with a bright solid "signal" dot traveling it. */
      @media (prefers-reduced-motion: reduce) {
        #pac-wires animateMotion {
          display: none;
        }
      }

      /* terminal renderer — a FIXED pixel grid. Each cell is a rigid box sized by
         --tui (so a frame can scale the whole board); the glyph is scaled to fit,
         so nothing can widen a row. */
      .pac-tui {
        --tui: 16px;
        display: inline-block;
        color: var(--color-up);
        line-height: 0;
        user-select: none;
      }
      .tui-row {
        display: flex;
        height: var(--tui);
      }
      .tui-cell {
        box-sizing: border-box;
        display: flex;
        align-items: center;
        justify-content: center;
        width: var(--tui);
        min-width: var(--tui);
        max-width: var(--tui);
        height: var(--tui);
        flex: 0 0 var(--tui);
        overflow: hidden;
        font-size: calc(var(--tui) * 0.75);
        line-height: 1;
      }

      /* ====================================================================
         THREE FRAMES: the same machine state, rendered into three device
         chassis (laptop · iPhone · terminal). Static — the whole pitch in one
         glance: one behavior, many renderers.
         ==================================================================== */
      .stage-label {
        margin-top: 0.75rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 12px;
        color: var(--color-muted);
        text-align: center;
      }
      .stage-label b {
        color: var(--color-fg);
        font-weight: 600;
      }

      /* the game inside a frame renders smaller than the hero board. Each device
         picks its own --tui so the LAPTOP reads biggest, the TERMINAL mid, the
         iPHONE smallest. Each screen wraps the game snugly — no dead space. */
      .frame {
        user-select: none;
      }
      .frame .frame-tui {
        --tui: 11px;
      }
      /* sized so the board fits each screen: laptop 350×270 → ~17px; terminal
         square → 13px; iPhone 75px wide → ~5px. */
      .laptop .frame-tui {
        --tui: 17px;
      }
      .terminal .frame-tui {
        --tui: 13px;
      }
      /* LAPTOP: a lid holding a BROWSER window, on a tapered base bar */
      .laptop {
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .laptop-screen {
        display: flex;
        flex-direction: column;
        /* smaller on mobile so it fits the screen; full size at md+ */
        width: 280px;
        height: 216px;
        background: #0c0d10;
        border: 8px solid #1c1e24;
        border-bottom-width: 14px;
        border-radius: 0.9rem 0.9rem 0.4rem 0.4rem;
        overflow: hidden;
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
      }
      @media (min-width: 768px) {
        .laptop-screen {
          width: 350px;
          height: 270px;
        }
      }
      /* the browser chrome inside the screen */
      .browser-bar {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.4rem 0.6rem;
        background: #2a2d35;
        border-bottom: 1px solid #14161b;
      }
      .browser-dots {
        display: flex;
        gap: 4px;
      }
      .browser-dots i {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #4a4d57;
      }
      .browser-dots i:nth-child(1) {
        background: #ff5d52;
      }
      .browser-dots i:nth-child(2) {
        background: #ffe66d;
      }
      .browser-dots i:nth-child(3) {
        background: #a2e57b;
      }
      .browser-url {
        flex: 1;
        padding: 2px 8px;
        border-radius: 999px;
        background: #16181e;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 9px;
        color: #8a8f9a;
        text-align: center;
      }
      /* the page area below the chrome bar fills the rest of the 350×270 screen,
         the game centred inside it. */
      .browser-body {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0c0d10;
      }
      .laptop-base {
        position: relative;
        width: 128%;
        height: 13px;
        background: linear-gradient(#d7d7de, #aeaeb8);
        border-radius: 0 0 0.4rem 0.4rem;
        box-shadow: inset 0 2px 3px rgba(0, 0, 0, 0.18);
      }
      /* the trackpad notch on the laptop hinge */
      .laptop-base::before {
        content: "";
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 16%;
        height: 5px;
        background: #9b9ba6;
        border-radius: 0 0 6px 6px;
      }
      /* IPHONE: rounded titanium body, side rails, Dynamic Island + home bar */
      .iphone {
        position: relative;
        background: #0c0d10;
        border: 3px solid #2c2e35;
        border-radius: 1.1rem;
        padding: 0.25rem;
        box-shadow:
          inset 0 0 0 1px rgba(255, 255, 255, 0.05),
          0 18px 40px rgba(0, 0, 0, 0.22);
      }
      /* side rails (volume + power buttons) */
      .iphone::before,
      .iphone::after {
        content: "";
        position: absolute;
        width: 2px;
        border-radius: 2px;
        background: #2c2e35;
      }
      .iphone::before {
        left: -4px;
        top: 28%;
        height: 14%;
      }
      .iphone::after {
        right: -4px;
        top: 24%;
        height: 22%;
      }
      /* Dynamic Island */
      .iphone-island {
        position: absolute;
        top: 0.5rem;
        left: 50%;
        transform: translateX(-50%);
        width: 40%;
        height: 9px;
        background: #000;
        border-radius: 999px;
        z-index: 2;
      }
      /* portrait phone screen: tall (9 : 19.5), game centred and large enough
         to read. */
      .iphone-screen {
        width: 116px;
        aspect-ratio: 9 / 19.5;
        border-radius: 1.1rem;
        overflow: hidden;
        background: #0c0d10;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .iphone .frame-tui {
        --tui: 8px; /* 13 × 8 = 104px, fits the 116px screen */
        width: 104px;
      }
      /* home indicator bar */
      .iphone-home {
        position: absolute;
        bottom: 0.45rem;
        left: 50%;
        transform: translateX(-50%);
        width: 36%;
        height: 3px;
        border-radius: 2px;
        background: rgba(255, 255, 255, 0.55);
        z-index: 2;
      }
      /* TERMINAL: title bar with traffic-light dots */
      .terminal {
        background: var(--color-code);
        border: 1px solid var(--color-code-border);
        border-radius: 0.7rem;
        overflow: hidden;
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
      }
      .terminal-bar {
        display: flex;
        gap: 6px;
        padding: 0.55rem 0.75rem;
        border-bottom: 1px solid var(--color-code-border);
      }
      .terminal-bar span {
        width: 10px;
        height: 10px;
        border-radius: 50%;
      }
      /* the terminal body wraps the game snugly — the game fills it */
      .terminal-body {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem;
      }

      /* HUGE screens: scale the three device frames up so they fill the wider
         container instead of floating small. Boards grow with their --tui. */
      @media (min-width: 1800px) {
        .laptop-screen {
          width: 440px;
          height: 340px;
        }
        .laptop .frame-tui {
          --tui: 22px;
        }
        .iphone-screen {
          width: 150px;
        }
        .iphone .frame-tui {
          --tui: 10px;
          width: 130px;
        }
        .terminal .frame-tui {
          --tui: 17px;
        }
        .stage-label {
          font-size: 14px;
        }
      }

      /* ====================================================================
         CASSETTE — the running game is dressed as a chunky game cartridge: a
         thick dark shell around the screen and a BIG bottom deck that the
         play/pause buttons sit on (like a cassette's lower half).
         ==================================================================== */
      .cassette {
        position: relative;
        border: 6px solid #0c0d10;
        border-radius: 1rem;
        background: #15171c; /* shell colour shows around the screen */
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.06),
          0 1px 2px rgba(0, 0, 0, 0.1),
          0 16px 40px rgba(0, 0, 0, 0.22);
      }
      /* the BIG bottom deck — the cartridge's lower shell; play/pause ride here.
         Hidden on mobile (the game it controls is hidden there too). */
      .cassette-deck {
        position: relative;
        margin-top: 0.25rem;
        padding: 1.1rem 1rem 1.25rem;
        background: linear-gradient(180deg, #20232b 0%, #15171c 100%);
        border-top: 2px solid #0c0d10;
        /* twin reel hubs hinting at a cassette tape */
        display: none;
        justify-content: center;
      }
      @media (min-width: 1024px) {
        .cassette-deck {
          display: flex;
        }
      }

      /* ====================================================================
         CONSOLE — the hub the cassette's cable plugs into, sitting just above
         the lined-up frames. Permanently wired to all three (always live).
         ==================================================================== */
      .console {
        position: relative;
        padding: 1rem 1.1rem 0.85rem;
        border-radius: 0.5rem 0.5rem 0.65rem 0.65rem;
        background: linear-gradient(180deg, #2a2c33 0%, #1d1f25 100%);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.08),
          inset 0 -3px 6px rgba(0, 0, 0, 0.4);
      }
      /* the cartridge slot the cassette's cable enters */
      .console-slot {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 62%;
        height: 12px;
        border-radius: 3px;
        background: #0c0d10;
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.7);
      }
      .console-label {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
      }
      .console-text {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.14em;
        color: #c9ccd6;
      }
      /* power LED — steady green (the demo is always live) */
      .console-led {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #a2e57b;
        box-shadow: 0 0 6px 1px rgba(162, 229, 123, 0.7);
      }

      /* ====================================================================
         LAB SECTION — dark full-width strip with two live demos
         ==================================================================== */
      .lab-section {
        padding: 5rem 1.5rem 5.5rem;
      }
      .lab-inner {
        max-width: 80rem;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
      }
      @media (min-width: 1024px) {
        .lab-inner {
          grid-template-columns: 1fr 1.4fr 1.4fr;
          gap: 3rem;
          align-items: start;
        }
      }

      /* title column */
      .lab-eyebrow {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(242, 255, 252, 0.4);
        margin-bottom: 1.25rem;
      }
      .lab-heading {
        font-size: 2.5rem;
        font-weight: 800;
        line-height: 1.06;
        letter-spacing: -0.02em;
      }
      @media (min-width: 1800px) {
        .lab-heading {
          font-size: 3.25rem;
        }
      }
      .lab-sub {
        margin-top: 1.25rem;
        font-size: 1rem;
        line-height: 1.65;
        max-width: 26ch;
      }

      /* demo card shared */
      .lab-demo {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.09);
        border-radius: 1.25rem;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: radial-gradient(
          120% 80% at 10% 0%,
          #15171c 0%,
          #0b0c0f 60%,
          #050507 100%
        );
        color: #f2fffc;
      }
      .lab-demo-header {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
        background: rgba(255, 255, 255, 0.03);
      }
      .lab-demo-icon {
        font-size: 1rem;
        line-height: 1;
      }
      .lab-demo-title {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(242, 255, 252, 0.6);
        flex: 1;
      }
      .lab-demo-badge {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 2px 8px;
        border-radius: 999px;
        background: #6b7678;
        color: #fff;
        transition:
          background 0.25s ease,
          color 0.25s ease;
      }
      .lab-demo-body {
        padding: 1.25rem;
        flex: 1;
      }
      #demo-whiteboard .lab-demo-body {
        padding: 0;
      }
      .lab-demo-footer {
        padding: 0.75rem 1.25rem;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }
      .lab-code-hint {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 10px;
        color: rgba(242, 255, 252, 0.3);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
      }

      /* ---- TRADING PANEL ---- */
      .trade-symbols {
        display: flex;
        gap: 0;
        margin-bottom: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.6rem;
        overflow: hidden;
      }
      .trade-sym {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.1rem;
        padding: 0.55rem 0.7rem 0.5rem;
        background: transparent;
        border: none;
        border-right: 1px solid rgba(255, 255, 255, 0.08);
        cursor: pointer;
        transition: background 0.15s;
        text-align: left;
      }
      .trade-sym:last-child {
        border-right: none;
      }
      .trade-sym:hover {
        background: rgba(255, 255, 255, 0.05);
      }
      .trade-sym-active {
        background: rgba(255, 255, 255, 0.09) !important;
      }
      .trade-sym-name {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(242, 255, 252, 0.4);
        line-height: 1;
      }
      .trade-sym-active .trade-sym-name {
        color: rgba(242, 255, 252, 0.75);
      }
      .trade-sym-price {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 12px;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
        color: #f2fffc;
        line-height: 1.2;
        white-space: nowrap;
      }
      .trade-sym-arrow {
        font-size: 8px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        line-height: 1;
      }
      .trade-sym-arrow.up {
        color: #a2e57b;
      }
      .trade-sym-arrow.down {
        color: #ff5d52;
      }

      @keyframes flash-up {
        0% {
          background: rgba(162, 229, 123, 0.18);
        }
        100% {
          background: transparent;
        }
      }
      @keyframes flash-down {
        0% {
          background: rgba(255, 93, 82, 0.18);
        }
        100% {
          background: transparent;
        }
      }
      .flash-up {
        animation: flash-up 0.35s ease-out forwards;
      }
      .flash-down {
        animation: flash-down 0.35s ease-out forwards;
      }
      .trade-sym-active.flash-up {
        animation: flash-up 0.35s ease-out forwards;
      }
      .trade-sym-active.flash-down {
        animation: flash-down 0.35s ease-out forwards;
      }

      .trade-ticker {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
      }
      .trade-price {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 1.85rem;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
        color: #f2fffc;
        letter-spacing: -0.02em;
      }
      .trade-delta {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.8rem;
        font-variant-numeric: tabular-nums;
        font-weight: 600;
      }
      .trade-delta.up {
        color: #a2e57b;
      }
      .trade-delta.down {
        color: #ff5d52;
      }

      .trade-chart {
        display: block;
        width: 100%;
        height: 52px;
        margin-bottom: 0.85rem;
        opacity: 0.9;
      }

      .trade-order {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.85rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 11px;
      }
      .trade-order-label {
        color: rgba(242, 255, 252, 0.3);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 9px;
      }
      .trade-order-val {
        font-variant-numeric: tabular-nums;
        color: rgba(242, 255, 252, 0.65);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .trade-order-val.up {
        color: #a2e57b;
      }
      .trade-order-val.down {
        color: #ff5d52;
      }

      .trade-controls {
        display: flex;
        gap: 0.4rem;
      }
      .trade-btn {
        flex: 1;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        padding: 0.5rem 0.2rem;
        border-radius: 0.5rem;
        border: 1px solid transparent;
        cursor: pointer;
        transition: filter 0.15s ease;
      }
      .trade-btn:disabled {
        opacity: 0.22;
        cursor: not-allowed;
      }
      .trade-btn-buy {
        background: #a2e57b;
        color: #0a1a06;
        border-color: #a2e57b;
      }
      .trade-btn-sell {
        background: #ff5d52;
        color: #fff;
        border-color: #ff5d52;
      }
      .trade-btn-cancel {
        background: transparent;
        color: rgba(242, 255, 252, 0.45);
        border-color: rgba(255, 255, 255, 0.14);
      }
      .trade-btn:not(:disabled):hover {
        filter: brightness(1.14);
      }

      /* ---- ACCORDION (shared by both demos) ---- */
      .trade-accordion {
        border-top: 1px solid rgba(255, 255, 255, 0.07);
      }
      .trade-accordion-trigger {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.65rem 1.25rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(242, 255, 252, 0.35);
        background: transparent;
        border: none;
        cursor: pointer;
        transition: color 0.15s;
      }
      .trade-accordion-trigger:hover {
        color: rgba(242, 255, 252, 0.65);
      }
      .trade-accordion-chevron {
        font-size: 9px;
        transition: transform 0.2s;
      }
      .trade-accordion-panel {
        padding: 0;
      }
      .trade-code {
        margin: 0;
        padding: 0.9rem 1.25rem 1rem;
        font-size: 11px;
        line-height: 1.7;
        background: rgba(0, 0, 0, 0.25);
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        overflow-x: auto;
      }

      /* ---- WHITEBOARD DEMO ---- */
      .wb-canvas {
        position: relative;
        width: 100%;
        height: 295px;
        background:
          radial-gradient(
            ellipse 80% 60% at 60% 40%,
            rgba(109, 92, 240, 0.06),
            transparent 70%
          ),
          #f8f9fc;
        border-radius: 0.75rem 0.75rem 0 0;
        overflow: hidden;
        /* dot grid */
        background-image:
          radial-gradient(
            circle,
            rgba(109, 92, 240, 0.18) 1px,
            transparent 1px
          ),
          radial-gradient(
            ellipse 80% 60% at 60% 40%,
            rgba(109, 92, 240, 0.04),
            transparent 70%
          );
        background-size:
          22px 22px,
          100% 100%;
        background-color: #f8f9fc;
        cursor: default;
        user-select: none;
      }

      .wb-cursor {
        position: absolute;
        pointer-events: none;
        transform: translate(-2px, -2px);
        z-index: 2;
      }
      .wb-cursor svg {
        display: block;
        filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.18));
      }
      .wb-cursor-label {
        position: absolute;
        top: 16px;
        left: 10px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 9px;
        font-weight: 600;
        color: #fff;
        padding: 1px 5px;
        border-radius: 3px;
        white-space: nowrap;
        pointer-events: none;
      }

      .wb-sticky {
        position: absolute;
        width: 120px;
        min-height: 72px;
        border-radius: 4px;
        padding: 0.55rem 0.65rem 0.45rem;
        box-shadow:
          2px 3px 8px rgba(0, 0, 0, 0.14),
          0 1px 2px rgba(0, 0, 0, 0.08);
        cursor: grab;
        z-index: 3;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        transition:
          box-shadow 0.15s,
          transform 0.15s;
        touch-action: none;
      }
      .wb-sticky:hover {
        box-shadow: 3px 5px 14px rgba(0, 0, 0, 0.18);
      }
      .wb-sticky-dragging {
        cursor: grabbing !important;
        box-shadow: 6px 10px 24px rgba(0, 0, 0, 0.22) !important;
        transform: rotate(1.5deg) scale(1.03) !important;
        z-index: 10 !important;
      }
      .wb-sticky-text {
        font-size: 11px;
        line-height: 1.45;
        color: rgba(22, 22, 26, 0.82);
        white-space: pre-line;
        pointer-events: none;
        flex: 1;
      }
      .wb-sticky-state {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 8px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(22, 22, 26, 0.38);
        pointer-events: none;
      }

      /* the three frames are always live — black, always-connected cables */
      .cable {
        fill: none;
        stroke: #15171c;
        stroke-width: 2.5;
        stroke-linejoin: round;
        stroke-linecap: round;
      }
      .cable-plug {
        fill: #15171c;
      }
    </style>
  </body>
</html>
