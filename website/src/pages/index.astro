---
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL;
const repo = "https://github.com/dunky-dev/state-machine";

// The three machines, written out (set:html so literal braces survive the JSX
// parser) — faithful to the real @dunky-dev/state-machine API + the pacman demo:
// `const x = machine({...})`, `on: { EVENT: { target, actions: act(...) } }`,
// and compose() members driven independently via .send({ type }).
const pacmanCode = `<span class="cmt">// 🟡 pacman — eats until the ghost gets him</span>
<span class="kw">const</span> pacman = <span class="fn">machine</span>({
  initial: <span class="str">'eating'</span>,
  context: { x: <span class="num">1</span>, y: <span class="num">1</span>, dir: <span class="str">'right'</span>, mouth: <span class="str">'open'</span> },
  states: {
    <span class="st" data-machine="pacman" data-state="eating">eating</span>: { on: {
      step: { actions: <span class="fn">act</span>($ => ({ x: $.event.x, y: $.event.y })) },
      die:  { target: <span class="str">'dead'</span> },
    } },
    <span class="st" data-machine="pacman" data-state="dead">dead</span>: { on: { revive: { target: <span class="str">'eating'</span> } } },
  },
})`;

const ghostCode = `<span class="cmt">// 👻 ghost — chases on each tick, stops on a catch</span>
<span class="kw">const</span> ghost = <span class="fn">machine</span>({
  initial: <span class="str">'roaming'</span>,
  context: { x: <span class="num">11</span>, y: <span class="num">10</span>, dir: <span class="str">'up'</span> },
  states: {
    <span class="st" data-machine="ghost" data-state="roaming">roaming</span>: { on: {
      tick: { actions: <span class="fn">act</span>($ => chase($.context, $.event)) },
      stop: { target: <span class="str">'stopped'</span> },
    } },
    <span class="st" data-machine="ghost" data-state="stopped">stopped</span>: { on: { reset: { target: <span class="str">'roaming'</span> } } },
  },
})`;

const boardCode = `<span class="cmt">// 🍒 board — dots, cherry, score</span>
<span class="kw">const</span> board = <span class="fn">machine</span>({
  initial: <span class="str">'playing'</span>,
  context: { dots, cherry, score: <span class="num">0</span> },
  states: {
    <span class="st" data-machine="board" data-state="playing">playing</span>: { on: {
      eat:    { actions: <span class="fn">act</span>($ => scoreAt($.context, $.event)) },
      caught: { target: <span class="str">'caught'</span> },
    } },
    <span class="st" data-machine="board" data-state="caught">caught</span>: { on: { reset: { target: <span class="str">'playing'</span> } } },
  },
})`;

const composeCode = `<span class="cmt">// ⏱️ a clock machine self-drives via \`after\` — no external loop</span>
<span class="kw">const</span> clock = <span class="fn">machine</span>({
  initial: <span class="str">'running'</span>,
  states: { <span class="st">running</span>: { after: { <span class="num">200</span>: { target: <span class="str">'running'</span> } } } },
})

<span class="cmt">// 🎲 compose the four; sync() fans each beat to all regions in order</span>
<span class="kw">const</span> game = <span class="fn">compose</span>({ clock, pacman, ghost, board })
game.<span class="fn">sync</span>(() => {
  <span class="kw">const</span> { x, y } = step(pacman.context)
  pacman.<span class="fn">send</span>({ type: <span class="str">'step'</span>, x, y })
  board.<span class="fn">send</span>({ type: <span class="str">'eat'</span>, x, y })
  ghost.<span class="fn">send</span>({ type: <span class="str">'tick'</span>, targetX: x, targetY: y })
})

game.<span class="fn">start</span>()`;

// the closing quick-start — a real, minimal machine (matches the README).
const quickStartCode = `<span class="kw">import</span> { machine, act } <span class="kw">from</span> <span class="str">'@dunky-dev/state-machine'</span>

<span class="kw">const</span> toggle = <span class="fn">machine</span>({
  initial: <span class="str">'inactive'</span>,
  context: { count: <span class="num">0</span> },
  states: {
    inactive: { on: { flip: { target: <span class="str">'active'</span>, actions: <span class="fn">act</span>($ => ({ count: $.context.count + <span class="num">1</span> })) } } },
    active:   { on: { flip: { target: <span class="str">'inactive'</span> } } },
  },
})

toggle.<span class="fn">start</span>()
toggle.<span class="fn">send</span>({ type: <span class="str">'flip'</span> })
toggle.state    <span class="cmt">// 'active'</span>
toggle.context  <span class="cmt">// { count: 1 }</span>`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dunky — a state machine built for performance</title>
    <link rel="icon" href={`${base}logo-symbol.svg`} type="image/svg+xml" />
    <meta
      name="description"
      content="A state machine built for performance — inspired by XState and Zag. Define a behavior once, render it anywhere."
    />
  </head>
  <body>
    <Header revealOnScroll />

    <main
      class="mx-auto max-w-5xl px-4 pb-16 sm:px-6 xl:max-w-6xl 2xl:max-w-[88rem] min-[1800px]:max-w-[104rem]"
    >
      <!-- HERO + FAST MACHINES share ONE grid so the game panel can use native
           `position: sticky` (no JS scroll transform → no flicker). On lg it's a
           5-col grid: copy (3/5) over the code (3/5) on the left, and the game
           (2/5) spanning BOTH rows on the right — that tall right cell is what
           lets the sticky game ride down past the hero and through "Fast
           machines", releasing at the grid's end. On mobile it's one column,
           ordered copy → game → code. -->
      <div
        class="grid grid-cols-1 items-start gap-10 lg:items-stretch lg:grid-cols-5 lg:gap-x-12 lg:gap-y-0"
      >
        <!-- the polished DX-lib copy column (top-left) — fills the first screen -->
        <section
          class="order-1 flex flex-col lg:justify-center lg:col-span-3 lg:col-start-1 lg:row-start-1"
        >
          <!-- brand lockup: Dunky wordmark logo + STATE-MACHINE eyebrow. -->
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
            <img src={`${base}logo.svg`} alt="Dunky" class="h-12" />
            <span class="select-none" aria-hidden="true">/</span>
            <span class="mt-2 font-mono text-lg font-semibold uppercase">
              State&#8209;Machine
            </span>
          </div>

          <!-- headline -->
          <h1
            class="mt-8 text-5xl font-bold leading-[1.04] tracking-tight sm:text-6xl lg:text-6xl 2xl:text-7xl min-[1800px]:text-8xl"
          >
            Define states once.<br />
            <span
              class="bg-linear-to-r from-accent to-[#22c5d3] bg-clip-text text-transparent"
              >Render it anywhere.</span
            >
          </h1>

          <!-- subhead -->
          <p
            class="mt-6 max-w-xl text-lg text-muted sm:text-xl 2xl:max-w-2xl 2xl:text-2xl"
          >
            <strong class="font-semibold text-fg"
              >A state machine built for performance</strong
            >
            <br />
            States as pure, serializable data you can plug into anything that renders.
            Inspired by
            <a
              class="text-accent hover:underline"
              href="https://stately.ai/docs"
              target="_blank"
              rel="noreferrer">XState</a
            >
            and
            <a
              class="text-accent hover:underline"
              href="https://zagjs.com/"
              target="_blank"
              rel="noreferrer">Zag</a
            >.
          </p>

          <!-- CTAs -->
          <div class="mt-9 flex flex-wrap items-center gap-3.5">
            <a
              class="rounded-xl bg-fg px-6 py-3 font-semibold text-bg transition-opacity hover:opacity-90"
              href={`${base}get-started`}>Get started →</a
            >
            <a
              class="rounded-xl border border-border bg-bg/60 px-6 py-3 font-semibold text-fg transition-colors hover:border-fg"
              href={repo}
              target="_blank"
              rel="noreferrer">GitHub</a
            >
          </div>

          <!-- install command -->
          <div
            class="mt-8 flex max-w-full items-center gap-3 self-start overflow-x-auto rounded-xl border border-border bg-panel/80 px-4 py-2.5 font-mono text-sm shadow-sm backdrop-blur"
          >
            <span class="select-none text-muted">$</span>
            <code id="install-cmd" class="whitespace-nowrap text-fg"
              >npm i @dunky-dev/state-machine</code
            >
            <button
              id="install-copy"
              type="button"
              aria-label="Copy install command"
              class="-mr-1 ml-1 shrink-0 rounded-md p-1.5 text-muted transition-colors hover:bg-black/5 hover:text-fg"
            >
              ⧉
            </button>
          </div>
        </section>

        <!-- FEATURE BAND — three value props, right after the hero. Sits in the
             left column (row 2); its dark background bleeds to the LEFT viewport
             edge while the text stays aligned with the rest of the left content.
             Three lined up on lg, stacked on mobile. -->
        <section
          class="band-left order-2 mt-12 lg:mt-24 lg:col-span-3 lg:col-start-1 lg:row-start-2"
        >
          <div class="band-left-bg" aria-hidden="true"></div>
          <div class="relative py-16 sm:py-20">
            <p class="band-eyebrow">Why Dunky</p>
            <ul class="mt-8 flex flex-col">
              <li class="band-item">
                <span class="band-num">🌎</span>
                <div class="band-body">
                  <h3 class="band-title">Truly agnostic</h3>
                  <p class="band-muted">
                    No environment assumption at all — one step beyond Zag's
                    headless idea. <a
                      class="band-link"
                      href={`${base}comparison`}>Compare →</a
                    >
                  </p>
                </div>
              </li>
              <li class="band-item">
                <span class="band-num">⚡️</span>
                <div class="band-body">
                  <h3 class="band-title">Fast at scale</h3>
                  <p class="band-muted">
                    ~8× XState's throughput, flat-ish memory, surgical
                    re-renders. <a class="band-link" href={`${base}benchmark`}
                      >See the benchmark →</a
                    >
                  </p>
                </div>
              </li>
              <li class="band-item">
                <span class="band-num">🧠</span>
                <div class="band-body">
                  <h3 class="band-title">Behavior, not render</h3>
                  <p class="band-muted">
                    A pure behavioral kernel — states, events, context. Runs on
                    the DOM, React Native, or any JS runtime.
                  </p>
                </div>
              </li>
            </ul>
          </div>
        </section>

        <!-- FAST MACHINES: the machine configs behind the live demo. Left 60%
             (row 3) so the game slides down the right 40% past the snippets. -->
        <section
          class="order-3 lg:col-span-3 lg:col-start-1 lg:row-start-3 mt-8 lg:mt-24"
          aria-label="The Dunky machines behind the demo"
        >
          <div class="mb-8">
            <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
              Fast machines
            </h2>
            <p class="mt-3 text-lg text-muted">
              Few bytes of state, events and context per machine. A tiny
              footprint can spin up thousands of them
              <br />
              <br />
              Built for <strong class="font-semibold text-fg"
                >high density × high frequency</strong
              >.
            </p>
          </div>

          <!-- all four snippets in ONE dark "IDE" card — three machine files +
               the compose that unites them — each with its own filename header,
               separated by hairline dividers. An emoji prefix tells them apart. -->
          <div class="dark-card ide-card">
            <pre
              class="overflow-x-auto px-4 py-3 font-mono text-[12px] leading-relaxed"><code set:html={pacmanCode} /></pre>

            <pre
              class="overflow-x-auto px-4 py-3 font-mono text-[12px] leading-relaxed"><code set:html={ghostCode} /></pre>

            <pre
              class="overflow-x-auto px-4 py-3 font-mono text-[12px] leading-relaxed"><code set:html={boardCode} /></pre>

            <pre
              class="overflow-x-auto px-4 py-3 font-mono text-[12px] leading-relaxed"><code set:html={composeCode} /></pre>
          </div>
        </section>

        <!-- RIGHT cell (~40%): the LIVE machine panel, spanning ALL THREE grid
             rows so its tall cell gives `position: sticky` room to ride down —
             the game slides past the hero, the "Fast machines" snippets, and
             comes to rest in the SNES dock beside "One machine". On mobile it
             sits right after the hero copy (order-2). -->
        <div
          class="hidden lg:block lg:col-span-2 lg:col-start-4 lg:row-span-3 lg:row-start-1 z-10 -mb-[275px]"
        >
          <div
            id="hero-live"
            class="relative md:ml-auto md:w-[362px] lg:sticky lg:top-30 lg:w-[465px] 2xl:w-[540px] min-[1800px]:w-[600px]"
          >
            <!-- the running game, dressed up as a game CASSETTE TAPE that slides
                 down and docks into the console near the frames below -->
            <div id="pac-card" class="cassette dark-card relative">
              <!-- the three machines' live state as a fixed-layout table -->
              <table
                class="pac-table hidden w-full font-mono text-[10px] sm:text-[11px] lg:table"
              >
                <thead>
                  <tr
                    class="panel-head text-left text-[9px] uppercase tracking-wider"
                  >
                    <th class="px-3 py-2 font-medium">machine</th>
                    <th class="px-1 py-2 font-medium">state</th>
                    <th class="px-2 py-2 font-medium">context</th>
                  </tr>
                </thead>
                <tbody>
                  <tr id="row-pacman" class="">
                    <td class="px-3 py-1.5 text-[#ffe66d]"
                      ><span aria-hidden="true">⚙️</span> pacman</td
                    >
                    <td id="st-pacman" class="px-1 py-1.5">…</td>
                    <td id="cx-pacman" class="cx-cell px-3 py-1.5"> </td>
                  </tr>
                  <tr id="row-ghost" class="">
                    <td class="px-3 py-1.5 text-[#62b3ff]"
                      ><span aria-hidden="true">⚙️</span> ghost</td
                    >
                    <td id="st-ghost" class="px-1 py-1.5">…</td>
                    <td id="cx-ghost" class="cx-cell px-3 py-1.5"> </td>
                  </tr>
                  <tr id="row-board" class="">
                    <td class="px-3 py-1.5 text-[#ff5d52]"
                      ><span aria-hidden="true">⚙️</span> board</td
                    >
                    <td id="st-board" class="px-1 py-1.5">…</td>
                    <td id="cx-board" class="cx-cell px-3 py-1.5"> </td>
                  </tr>
                </tbody>
              </table>

              <!-- routing band: the wires bow out past the card edge and back.
                   The game board + deck are hidden on mobile (lg+ only); the
                   live state TABLE above stays visible everywhere. -->
              <div class="hidden h-8 lg:block"></div>

              <!-- the game (board), centered. The wires bow OUTSIDE the card on
                   the right, then come back in to plug into the board's edge. -->
              <div class="hidden justify-center px-3 pb-3 lg:flex">
                <pre
                  id="render-tui"
                  class="pac-tui m-0 overflow-x-auto text-left font-mono leading-[1.05]"
                  aria-hidden="true">
                </pre>
              </div>

              <!-- the cassette's chunky BOTTOM SHELL — the play/pause sit on it -->
              <div class="cassette-deck">
                <!-- play / pause — two icon-only buttons on the cassette deck -->
                <div id="pac-controls" class="flex gap-1.5" data-paused="false">
                  <button
                    id="pac-play"
                    type="button"
                    aria-label="Play"
                    class="pac-ctrl rounded-lg p-2 text-muted transition-colors hover:text-fg"
                  >
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 16 16"
                      fill="currentColor"
                      aria-hidden="true"><path d="M4 2.5v11l9-5.5z"></path></svg
                    >
                  </button>
                  <button
                    id="pac-pause"
                    type="button"
                    aria-label="Pause"
                    class="pac-ctrl rounded-lg p-2 text-muted transition-colors hover:text-fg"
                  >
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 16 16"
                      fill="currentColor"
                      aria-hidden="true"
                      ><rect x="3.5" y="2.5" width="3" height="11" rx="1"
                      ></rect><rect x="9.5" y="2.5" width="3" height="11" rx="1"
                      ></rect></svg
                    >
                  </button>
                </div>
              </div>
              <!-- /cassette-deck -->
              <!-- the "connection" wires live on the (un-clipped) card so they can
                 bow OUTSIDE the black card before returning to the board. -->
              <svg
                id="pac-wires"
                class="pointer-events-none absolute inset-0 hidden h-full w-full overflow-visible lg:block"
                aria-hidden="true"></svg>
            </div>
            <!-- /cassette card -->

            <!-- FEED cable: from the cassette's bottom down to the console it
                 docks into. Lives on #hero-live so it tracks the sticky game; it
                 overflows downward to reach the console below. -->
            <svg
              id="feed-cable"
              class="pointer-events-none absolute inset-0 z-10 h-full w-full overflow-visible"
              aria-hidden="true"></svg>
          </div>
          <!-- /hero-live -->
        </div>
        <!-- /RIGHT column -->
      </div>
      <!-- /HERO + FAST MACHINES grid -->

      <!-- SHOWCASE: one big premium panel that unifies the "One machine" copy
           and the device lineup below it — breaks the rigid left/right split.
           The game cassette overlaps its top-right edge. -->
      <section class="showcase">
        <h2
          class="text-3xl font-bold leading-[1.08] tracking-tight sm:text-4xl 2xl:text-5xl"
        >
          One machine.<br />
          Rendered on any JS runner.
        </h2>
        <p class="mt-4 max-w-xl text-lg text-muted 2xl:text-xl">
          The machine is a <strong class="font-semibold text-fg"
            >pure kernel</strong
          > with no environment assumptions. Plug it into any JS UI. If JS runs it,
          <strong class="font-semibold text-fg">the machine drives it</strong>.
        </p>

        <!-- MOBILE-ONLY live state table — sits here, after the "One machine" copy.
             On lg+ the cassette card handles this; hidden there. -->
        <div class="mt-6 lg:hidden">
          <table
            class="pac-table dark-card w-full font-mono text-[10px] border-none! bg-black!"
          >
            <thead>
              <tr
                class="panel-head text-left text-[9px] uppercase tracking-wider"
              >
                <th class="px-3 py-2 font-medium">machine</th>
                <th class="px-1 py-2 font-medium">state</th>
                <th class="px-2 py-2 font-medium">context</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="px-3 py-1.5 text-[#ffe66d]"
                  ><span aria-hidden="true">⚙️</span> pacman</td
                >
                <td id="m-st-pacman" class="px-1 py-1.5">…</td>
                <td id="m-cx-pacman" class="cx-cell px-3 py-1.5"> </td>
              </tr>
              <tr>
                <td class="px-3 py-1.5 text-[#62b3ff]"
                  ><span aria-hidden="true">⚙️</span> ghost</td
                >
                <td id="m-st-ghost" class="px-1 py-1.5">…</td>
                <td id="m-cx-ghost" class="cx-cell px-3 py-1.5"> </td>
              </tr>
              <tr>
                <td class="px-3 py-1.5 text-[#ff5d52]"
                  ><span aria-hidden="true">⚙️</span> board</td
                >
                <td id="m-st-board" class="px-1 py-1.5">…</td>
                <td id="m-cx-board" class="cx-cell px-3 py-1.5"> </td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- BROADCAST: the cassette's cable runs down into the CONSOLE (hub),
             which fans out to the three frames. The frames are always live. -->
        <div id="broadcast" class="relative">
          <!-- the console the cassette's cable plugs into — the hub feeding all 3.
             SAME width as the cassette and right-aligned, so it sits perfectly
             under it. lg+ only. -->
          <div
            id="dock"
            class="console ml-auto hidden lg:block lg:w-[465px] 2xl:w-[540px] min-[1800px]:w-[600px]"
          >
            <span class="console-slot" aria-hidden="true"></span>
            <span class="console-label">
              <span class="console-led" aria-hidden="true"></span>
              <span class="console-text">ON / CH-03</span>
            </span>
          </div>

          <!-- black, rounded-corner cables: console → each frame, always connected
             (drawn by JS into this SVG, with a plug at each end). lg+ only. -->
          <svg
            id="cables"
            class="pointer-events-none absolute inset-0 z-10 h-full w-full overflow-visible"
            aria-hidden="true"></svg>

          <!-- mobile: all three stacked; md+: all three in one row -->
          <section
            class="mt-12 grid select-none grid-cols-1 items-end justify-items-center gap-10 sm:mt-24 md:grid-cols-3"
            aria-label="The same machine rendered in three frames"
          >
            <!-- LAPTOP — the screen shows a BROWSER window (chrome bar + URL) -->
            <figure id="frame-laptop" class="frame laptop">
              <div class="laptop-screen">
                <div class="browser-bar">
                  <span class="browser-dots" aria-hidden="true"
                    ><i></i><i></i><i></i></span
                  >
                  <span class="browser-url">dunky-dev.com</span>
                </div>
                <div class="browser-body">
                  <pre
                    class="frame-tui pac-tui m-0 text-left font-mono leading-[1.05]"
                    aria-hidden="true">
                  </pre>
                </div>
              </div>
              <div class="laptop-base"></div>
              <figcaption class="stage-label">
                <b>Web</b>
              </figcaption>
            </figure>

            <!-- IPHONE — rounded body, side rails, Dynamic Island, home bar.
               Nudged 50px right on lg for better centring in its column. -->
            <figure
              id="frame-phone"
              class="frame flex flex-col items-center lg:translate-x-[50px]"
            >
              <div class="iphone">
                <span class="iphone-island" aria-hidden="true"></span>
                <div class="iphone-screen">
                  <pre
                    class="frame-tui pac-tui m-0 text-left font-mono leading-[1.05]"
                    aria-hidden="true">
                  </pre>
                </div>
                <span class="iphone-home" aria-hidden="true"></span>
              </div>
              <figcaption class="stage-label">
                <b>Devices</b>
              </figcaption>
            </figure>

            <!-- TERMINAL -->
            <figure
              id="frame-terminal"
              class="frame flex flex-col items-center"
            >
              <div class="terminal">
                <div class="terminal-bar">
                  <span style="background:#ff5d52"></span>
                  <span style="background:#ffe66d"></span>
                  <span style="background:#a2e57b"></span>
                </div>
                <div class="terminal-body">
                  <pre
                    class="frame-tui pac-tui m-0 text-left font-mono leading-[1.05]"
                    aria-hidden="true">
                  </pre>
                </div>
              </div>
              <figcaption class="stage-label">
                <b>Terminals</b>
              </figcaption>
            </figure>
          </section>
        </div>
        <!-- /broadcast -->
      </section>
      <!-- /showcase -->
    </main>

    <!-- ORIGIN QUOTE -->
    <section class="origin-section">
      <div class="origin-inner">
        <div class="origin-layout">
          <!-- left: avatar -->
          <a
            href="https://x.com/ivanbanov"
            target="_blank"
            rel="noreferrer"
            class="origin-avatar-link"
            aria-label="Ivan Banov on X"
          >
            <img
