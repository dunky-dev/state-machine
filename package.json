{
  "name": "@render-experiment/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "tsx scripts/build.ts",
    "codegen:watch": "tsx scripts/watch.ts",
    "dev": "pnpm dev:react",
    "dev:react": "run-p codegen:watch dev:react:vite",
    "dev:react:vite": "pnpm --filter sandbox-react dev",
    "dev:native": "run-p codegen:watch dev:native:expo",
    "dev:native:expo": "pnpm --filter sandbox-native start",
    "build": "pnpm codegen && pnpm --filter sandbox-react build",
    "test": "vitest",
    "test:native": "jest --config jest.native.js",
    "test:all": "pnpm test && pnpm test:native",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.jest.json",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "prepare": "husky"
  },
  "devDependencies": {
    "@react-native/babel-preset": "^0.85.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/use-sync-external-store": "^1.5.0",
    "@vitejs/plugin-react": "^6.0.2",
    "chokidar": "^5.0.0",
    "csstype": "^3.2.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.4",
    "jsdom": "^29.1.1",
    "knip": "^6.15.0",
    "lint-staged": "^17.0.7",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-test-renderer": "19.2.6",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.20.0"
}
