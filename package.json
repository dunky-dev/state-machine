{
  "name": "@render-experiment/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "tsx scripts/build.ts",
    "codegen:watch": "tsx scripts/watch.ts",
    "dev": "pnpm dev:react",
    "dev:react": "run-p codegen:watch dev:react:vite",
    "dev:react:vite": "pnpm --filter sandbox-react dev",
    "dev:native": "run-p codegen:watch dev:native:expo",
    "dev:native:expo": "pnpm --filter sandbox-native start",
    "dev:pixi": "run-p codegen:watch dev:pixi:vite",
    "dev:pixi:vite": "pnpm --filter sandbox-pixi dev",
    "build": "pnpm codegen && pnpm --filter sandbox-react build",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/use-sync-external-store": "^1.5.0",
    "@vitejs/plugin-react": "^6.0.2",
    "chokidar": "^5.0.0",
    "csstype": "^3.2.3",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.20.0"
}
