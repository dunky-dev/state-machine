{
  "compilerOptions": {
    "target": "esnext",
    "allowJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitReturns": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@render-experiment/*-core": [
        "./packages/core/components/*/src",
        "./packages/core/*/src",
      ],
      "@render-experiment/*-react": [
        "./packages/react/components/*/src",
        "./packages/react/*/src",
      ],
      "@render-experiment/*-native": [
        "./packages/native/components/*/src",
        "./packages/native/*/src",
      ],
      "@render-experiment/*-pixi": [
        "./packages/pixi/components/*/src",
        "./packages/pixi/*/src",
      ],
      "@render-experiment/*-shared": ["./packages/shared/components/*/src"],
      "@render-experiment/utils": ["./packages/shared/utils/src"],
      "@render-experiment/store": ["./packages/core/store/src"],
    },
    "types": ["@types/node", "vite/client", "vitest/globals"],
  },
  "include": ["./*.ts", "./packages", "./sandbox", "./scripts"],
  "exclude": [
    "**/node_modules",
    "**/dist",
    // Jest tests (jest globals) are type-checked by tsconfig.native-tests.json,
    // not here — this project provides vitest globals, which collide with jest's.
    // (TS exclude globs don't support {ts,tsx} brace alternation — list both.)
    "**/*.native.test.ts",
    "**/*.native.test.tsx",
    "./jest.native.ts"
  ],
}
